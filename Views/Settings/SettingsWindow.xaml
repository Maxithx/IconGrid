<Window x:Class="IconGrid.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:IconGrid.Helpers" xmlns:views="clr-namespace:IconGrid.Views"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="Instillinger"
        Width="960"
        Height="720"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        FontFamily="Segoe UI Variable"
        MouseLeftButtonDown="SettingsWindow_MouseLeftButtonDown">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../StartsideStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <SolidColorBrush x:Key="ButtonHoverDark" Color="#2b2d31" />
            <SolidColorBrush x:Key="ButtonPressDark" Color="#2b2d31" />
            <SolidColorBrush x:Key="TitleBarGlyphBrush" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="SettingsTextFallbackBrush" Color="#FF3F3F46" />
            <SolidColorBrush x:Key="CaptionHoverLight" Color="#1A000000" />
            <SolidColorBrush x:Key="CaptionPressLight" Color="#33000000" />
            <SolidColorBrush x:Key="CaptionHoverDark" Color="#14FFFFFF" />
            <SolidColorBrush x:Key="CaptionPressDark" Color="#21FFFFFF" />

            <SolidColorBrush x:Key="SidebarItemHoverLight" Color="#E5E7EB" />
            <SolidColorBrush x:Key="SidebarNavigationHighlightDark" Color="#FF3E3E3E" />
            <SolidColorBrush x:Key="SidebarNavigationHighlightLight" Color="#FFE0E4E8" />
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground"
                    Value="{Binding DataContext.SettingsSubtextForeground, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue={StaticResource SettingsTextFallbackBrush}, TargetNullValue={StaticResource SettingsTextFallbackBrush}}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10 8" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                        <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                    <Condition Binding="{Binding DataContext.IsLightTheme, RelativeSource={RelativeSource AncestorType=Window}}" Value="False" />
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource SidebarNavigationHighlightDark}" />
                            </MultiDataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                    <Condition Binding="{Binding DataContext.IsLightTheme, RelativeSource={RelativeSource AncestorType=Window}}" Value="True" />
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource SidebarNavigationHighlightLight}" />
                            </MultiDataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsPressed, RelativeSource={RelativeSource Self}}" Value="True" />
                                    <Condition Binding="{Binding DataContext.IsLightTheme, RelativeSource={RelativeSource AncestorType=Window}}" Value="False" />
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource SidebarNavigationHighlightDark}" />
                            </MultiDataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsPressed, RelativeSource={RelativeSource Self}}" Value="True" />
                                    <Condition Binding="{Binding DataContext.IsLightTheme, RelativeSource={RelativeSource AncestorType=Window}}" Value="True" />
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource SidebarNavigationHighlightLight}" />
                            </MultiDataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Selected" />
                        <Condition Binding="{Binding DataContext.IsLightTheme, RelativeSource={RelativeSource AncestorType=Window}}" Value="False" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="{StaticResource SidebarNavigationHighlightDark}" />
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Selected" />
                        <Condition Binding="{Binding DataContext.IsLightTheme, RelativeSource={RelativeSource AncestorType=Window}}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="{StaticResource SidebarNavigationHighlightLight}" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="BackButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="4"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                    <Condition Binding="{Binding DataContext.IsLightTheme, RelativeSource={RelativeSource AncestorType=Window}}" Value="False" />
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource ButtonHoverDark}" />
                                <Setter TargetName="Root" Property="Padding" Value="6" />
                            </MultiDataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                    <Condition Binding="{Binding DataContext.IsLightTheme, RelativeSource={RelativeSource AncestorType=Window}}" Value="True" />
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource SidebarItemHoverLight}" />
                                <Setter TargetName="Root" Property="Padding" Value="6" />
                            </MultiDataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsPressed, RelativeSource={RelativeSource Self}}" Value="True" />
                                    <Condition Binding="{Binding DataContext.IsLightTheme, RelativeSource={RelativeSource AncestorType=Window}}" Value="False" />
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource ButtonPressDark}" />
                                <Setter TargetName="Root" Property="Padding" Value="6" />
                            </MultiDataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Tag" Value="Selected">
                    <Setter Property="Background" Value="{Binding DataContext.AccentBrush, RelativeSource={RelativeSource AncestorType=Window}}" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>

    <ControlTemplate x:Key="BackCaptionButtonTemplate" TargetType="Button">
        <Border x:Name="CaptionBorder"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="8,0,0,0"
                SnapsToDevicePixels="True">
            <ContentPresenter HorizontalAlignment="Center"
                              VerticalAlignment="Center" />
        </Border>
    </ControlTemplate>


        <ControlTemplate x:Key="CaptionButtonTemplate" TargetType="Button">
            <Border x:Name="CaptionBorder"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="0"
                    SnapsToDevicePixels="True">
                <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
            </Border>
        </ControlTemplate>

        <ControlTemplate x:Key="CloseCaptionButtonTemplate" TargetType="Button">
            <Border x:Name="CaptionBorder"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="0,8,0,0"
                    SnapsToDevicePixels="True">
                <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
            </Border>
        </ControlTemplate>

        <Style x:Key="CaptionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Template" Value="{StaticResource CaptionButtonTemplate}" />
            <Style.Triggers>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                        <Condition Binding="{Binding DataContext.IsDarkTheme, RelativeSource={RelativeSource AncestorType=Window}}" Value="False" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="{StaticResource CaptionHoverLight}" />
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                        <Condition Binding="{Binding DataContext.IsDarkTheme, RelativeSource={RelativeSource AncestorType=Window}}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="{StaticResource CaptionHoverDark}" />
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsPressed, RelativeSource={RelativeSource Self}}" Value="True" />
                        <Condition Binding="{Binding DataContext.IsDarkTheme, RelativeSource={RelativeSource AncestorType=Window}}" Value="False" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="{StaticResource CaptionPressLight}" />
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsPressed, RelativeSource={RelativeSource Self}}" Value="True" />
                        <Condition Binding="{Binding DataContext.IsDarkTheme, RelativeSource={RelativeSource AncestorType=Window}}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="{StaticResource CaptionPressDark}" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BackCaptionButtonStyle" TargetType="Button" BasedOn="{StaticResource CaptionButtonStyle}">
            <Setter Property="Content" Value="&#xE72B;" />
            <Setter Property="Foreground">
                <Setter.Value>
                    <Binding Path="DataContext.TopBarForeground"
                             RelativeSource="{RelativeSource AncestorType=Window}"
                             FallbackValue="{StaticResource TitleBarGlyphBrush}"
                             TargetNullValue="{StaticResource TitleBarGlyphBrush}" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template" Value="{StaticResource BackCaptionButtonTemplate}" />
        </Style>

        <Style x:Key="MaximizeCaptionButtonStyle" TargetType="Button" BasedOn="{StaticResource CaptionButtonStyle}">
            <Setter Property="Content" Value="&#xE922;" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized">
                    <Setter Property="Content" Value="&#xE923;" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CloseCaptionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Template" Value="{StaticResource CloseCaptionButtonTemplate}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123" />
                    <Setter Property="Foreground" Value="#FFFFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SettingsShellBorderStyle" TargetType="Border">
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#18000000" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8"
                                      ShadowDepth="0"
                                      Direction="270"
                                      Color="#33404040"
                                      Opacity="0.2" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsDarkTheme, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                    <Setter Property="BorderBrush" Value="#18FFFFFF" />
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="8"
                                              ShadowDepth="0"
                                              Direction="270"
                                              Color="#22000000"
                                              Opacity="0.16" />
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{Binding DataContext.SettingsCardBackground, RelativeSource={RelativeSource AncestorType=Window}}" />
            <Setter Property="BorderBrush" Value="{Binding DataContext.SettingsCardBorderBrush, RelativeSource={RelativeSource AncestorType=Window}}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10"
                                      ShadowDepth="2"
                                      Direction="270"
                                      Color="{Binding DataContext.SettingsShadowColor, RelativeSource={RelativeSource AncestorType=Window}}"
                                      Opacity="0.45" />
                </Setter.Value>
            </Setter>
        </Style>
        </ResourceDictionary>
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="48"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            CornerRadius="8"
                            UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

<Grid x:Name="WindowRoot"
      helpers:DevInspector.Metadata="Startside root → Views/SettingsWindow.xaml"
      Background="Transparent">
    <Border Style="{StaticResource SettingsShellBorderStyle}"
            Background="{Binding DataContext.TopBarBackground, RelativeSource={RelativeSource AncestorType=Window}}"
            CornerRadius="8"
            Padding="6"
            SnapsToDevicePixels="True"
            helpers:DevInspector.Metadata="Startside shell → Views/SettingsWindow.xaml">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  shell:WindowChrome.IsHitTestVisibleInChrome="True"
                  MouseLeftButtonDown="TitleBar_MouseDown"
                  VerticalAlignment="Top"
                  Margin="0,-2,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Style="{StaticResource BackCaptionButtonStyle}"
                        Click="CloseButton_Click"
                        Margin="-6,-4,0,0" />
                <Border Grid.Column="2"
                        Margin="12,0,0,0"
                        VerticalAlignment="Stretch"
                        Background="Transparent" />
        <StackPanel Grid.Column="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,-4,-6,0">
                    <Button x:Name="MinimizeCaptionButton"
                            Style="{StaticResource CaptionButtonStyle}"
                            ToolTip="Minimer vinduet"
                            Content="&#xE921;"
                            Click="MinimizeButton_Click" />
                    <Button x:Name="MaximizeRestoreButton"
                            Style="{StaticResource MaximizeCaptionButtonStyle}"
                            ToolTip="Maksimer/gendan"
                            Click="MaximizeButton_Click" />
                    <Button x:Name="CloseCaptionButton"
                            Style="{StaticResource CloseCaptionButtonStyle}"
                            ToolTip="Luk vinduet"
                            Content="&#xE711;"
                            Click="CloseButton_Click" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Sidebar navigation -->
                <Border Grid.Column="0"
                        Background="{Binding TopBarBackground}"
                        CornerRadius="12"
                        Padding="16"
                        helpers:DevInspector.Metadata="Startside navigation → Views/SettingsWindow.xaml">
                    <StackPanel>
                        <!-- Primary navigation buttons -->
                        <Button x:Name="StartsideNavButton"
                                Style="{StaticResource NavButtonStyle}"
                                Tag="Selected"
                                Margin="0,6,0,0"
                                AutomationProperties.Name="Startside"
                                Click="StartsideNavButton_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="28"
                                        Height="28"
                                        CornerRadius="6"
                                        Background="transparent"                                         >
                                    <Image Source="pack://siteoforigin:,,,/figma-icons/figma-logo-x4.png"
                                           Width="24"
                                           Height="24"
                                           Stretch="Uniform"
                                           Opacity="1" />
                                </Border>
                                <TextBlock Text="Startside"
                                           Margin="12,0,0,0"
                                           FontSize="14"
                                           VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}, FallbackValue={StaticResource SettingsTextFallbackBrush}, TargetNullValue={StaticResource SettingsTextFallbackBrush}}"/>
                            </StackPanel>
                        </Button>
                        <!-- Secondary navigation buttons -->
                        <Button x:Name="GenvejsNavButton"
                                Style="{StaticResource NavButtonStyle}"
                                Margin="0,6,0,0"
                                Click="GenvejsNavButton_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="28"
                                        Height="28"
                                        CornerRadius="6"
                                        Background="transparent">
                                    <Image Source="pack://siteoforigin:,,,/figma-icons/figma-genvejs-ikon-x4.png"
                                           Width="24"
                                           Height="24"
                                           Stretch="Uniform" />
                                </Border>
                                <TextBlock Margin="12,0,0,0"
                                           Text="Genvejs ikoner"
                                           FontSize="14"
                                           VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}, FallbackValue={StaticResource SettingsTextFallbackBrush}, TargetNullValue={StaticResource SettingsTextFallbackBrush}}" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="LayoutNavButton"
                                Style="{StaticResource NavButtonStyle}"
                                Margin="0,6,0,0"
                                Click="LayoutNavButton_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="28"
                                        Height="28"
                                        CornerRadius="6"
                                        Background="transparent">
                                    <Image Source="pack://siteoforigin:,,,/figma-icons/figma-Layout-ikon-x4.png"
                                           Width="24"
                                           Height="24"
                                           Stretch="Uniform" />
                                </Border>
                                <TextBlock Margin="12,0,0,0"
                                           Text="Layout"
                                           FontSize="14"
                                           VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}, FallbackValue={StaticResource SettingsTextFallbackBrush}, TargetNullValue={StaticResource SettingsTextFallbackBrush}}" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="HardwareNavButton"
                                Style="{StaticResource NavButtonStyle}"
                                Margin="0,6,0,0"
                                Click="HardwareNavButton_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="28"
                                        Height="28"
                                        CornerRadius="6"
                                        Background="{Binding AccentBrush}">
                                    <TextBlock Text="HW"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="White" />
                                </Border>
                                <TextBlock Margin="12,0,0,0"
                                           Text="Hardware"
                                           FontSize="14"
                                           VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}, FallbackValue={StaticResource SettingsTextFallbackBrush}, TargetNullValue={StaticResource SettingsTextFallbackBrush}}" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="HelpNavButton"
                                Style="{StaticResource NavButtonStyle}"
                                Margin="0,6,0,0"
                                Click="HelpNavButton_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="28"
                                        Height="28"
                                        CornerRadius="6"
                                        Background="transparent">
                                    <Image Source="pack://siteoforigin:,,,/figma-icons/help-icon-x4.png"
                                           Width="28"
                                           Height="28"
                                           Stretch="Uniform"
                                           Opacity="0.9" />
                                </Border>
                                <TextBlock Margin="12,0,0,0"
                                           Text="Hjælp"
                                           FontSize="14"
                                           VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}, FallbackValue={StaticResource SettingsTextFallbackBrush}, TargetNullValue={StaticResource SettingsTextFallbackBrush}}" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="AboutNavButton"
                                Style="{StaticResource NavButtonStyle}"
                                Margin="0,6,0,0"
                                Click="AboutNavButton_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="28"
                                        Height="28"
                                        CornerRadius="6"
                                        Background="transparent">
                                    <Image Source="pack://siteoforigin:,,,/figma-icons/figma-About-ikon-x4.png"
                                           Width="24"
                                           Height="24"
                                           Stretch="Uniform"
                                           Opacity="0.95" />
                                </Border>
                                <TextBlock Margin="12,0,0,0"
                                           Text="Om"
                                           FontSize="14"
                                           VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}, FallbackValue={StaticResource SettingsTextFallbackBrush}, TargetNullValue={StaticResource SettingsTextFallbackBrush}}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Style="{StaticResource StartsidePanelStyle}"
                        Padding="16"
                        helpers:DevInspector.Metadata="Startside host → Views/SettingsWindow.xaml">
                    <ContentControl x:Name="SettingsContentHost" />
                </Border>
            </Grid>
        </Grid>
    </Border>
    <Canvas x:Name="DevOverlayCanvas"
            Panel.ZIndex="150"
            IsHitTestVisible="False">
        <Border x:Name="DevOverlayPanel"
                Visibility="Collapsed"
                Canvas.Left="8"
                Canvas.Top="8"
                Padding="8"
                Background="#CC111720"
                CornerRadius="6"
                BorderBrush="#66FFFFFF"
                BorderThickness="1"
                Opacity="0.9"
                MinWidth="220"
                MaxWidth="320">
            <StackPanel>
                <TextBlock x:Name="DevOverlayHeader"
                           Foreground="White"
                           FontWeight="SemiBold"
                           FontSize="13"
                           TextWrapping="Wrap" />
                <TextBlock x:Name="DevOverlayDetails"
                           Foreground="#E5E7EB"
                           FontSize="11"
                           Margin="0,4,0,0"
                           TextWrapping="WrapWithOverflow" />
            </StackPanel>
        </Border>
    </Canvas>
</Grid>
</Window>
