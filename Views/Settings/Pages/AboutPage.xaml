<UserControl x:Class="IconGrid.Views.AboutPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:helpers="clr-namespace:IconGrid.Helpers"
             xmlns:views="clr-namespace:IconGrid.Views"
             mc:Ignorable="d"
             Background="Transparent">
    <views:TemplatePage Margin="12">
        <views:TemplatePage.HeroContent>
            <StackPanel helpers:DevInspector.Metadata="Om hero card → Views/AboutPage.xaml">
                <TextBlock FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{Binding DataContext.TopBarForeground, RelativeSource={RelativeSource AncestorType=Window}}"
                           Text="{Binding AboutTitleText}" />
                <TextBlock Margin="0,8,0,0"
                           FontSize="13"
                           TextWrapping="Wrap"
                           Foreground="{Binding DataContext.SettingsSubtextForeground, RelativeSource={RelativeSource AncestorType=Window}}"
                           Text="{Binding AboutIntroText}" />
            </StackPanel>
        </views:TemplatePage.HeroContent>
        <views:TemplatePage.CardsContent>
            <StackPanel>
                <Border Style="{StaticResource StartsideSectionCardStyle}"
                        MinHeight="160"
                        helpers:DevInspector.Metadata="About card → Views/AboutPage.xaml" />
                <Border Style="{StaticResource StartsideSectionCardStyle}"
                        MinHeight="160"
                        helpers:DevInspector.Metadata="About card 2 → Views/AboutPage.xaml" />
            </StackPanel>
        </views:TemplatePage.CardsContent>
    </views:TemplatePage>
</UserControl>
