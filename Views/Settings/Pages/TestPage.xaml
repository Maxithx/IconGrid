<UserControl x:Class="IconGrid.Views.TestPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:helpers="clr-namespace:IconGrid.Helpers"
             xmlns:views="clr-namespace:IconGrid.Views"
             mc:Ignorable="d"
             Background="Transparent"
             Loaded="UserControl_Loaded">
    <ScrollViewer Margin="12"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  CanContentScroll="False"
                  PanningMode="VerticalOnly">
        <ScrollViewer.Resources>
            <Style TargetType="ScrollBar" BasedOn="{StaticResource SettingsPageScrollBarStyle}" />
        </ScrollViewer.Resources>
        <views:TemplatePage Margin="0,0,8,0">
            <views:TemplatePage.HeroContent>
                <StackPanel helpers:DevInspector.Metadata="Test hero card -> Views/TestPage.xaml">
                <TextBlock FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{Binding DataContext.TopBarForeground, RelativeSource={RelativeSource AncestorType=Window}}"
                           Text="Debug / Test" />
                <Border Margin="0,10,0,0"
                        Padding="10,8"
                        CornerRadius="8"
                        Background="{Binding DataContext.SettingsCardBackground, RelativeSource={RelativeSource AncestorType=Window}}">
                    <TextBlock FontSize="12"
                               FontFamily="Consolas"
                               TextWrapping="Wrap"
                               Foreground="{Binding DataContext.SettingsSubtextForeground, RelativeSource={RelativeSource AncestorType=Window}}"
                               Text="{Binding SummaryText, RelativeSource={RelativeSource AncestorType={x:Type views:TestPage}}}" />
                </Border>
                <TextBlock Margin="0,8,0,0"
                           FontSize="13"
                           TextWrapping="Wrap"
                           Foreground="{Binding DataContext.SettingsSubtextForeground, RelativeSource={RelativeSource AncestorType=Window}}"
                           Text="This page helps compare startup state, elevation, and running instances of IconGrid." />
                </StackPanel>
            </views:TemplatePage.HeroContent>
            <views:TemplatePage.CardsContent>
                <StackPanel>
                <Border Style="{StaticResource StartsideSectionCardStyle}">
                    <StackPanel>
                        <TextBlock FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{Binding DataContext.TopBarForeground, RelativeSource={RelativeSource AncestorType=Window}}"
                                   Text="Current instance" />
                        <TextBlock Margin="0,10,0,0"
                                   FontFamily="Consolas"
                                   TextWrapping="Wrap"
                                   Foreground="{Binding DataContext.SettingsSubtextForeground, RelativeSource={RelativeSource AncestorType=Window}}"
                                   Text="{Binding InstanceInfo, RelativeSource={RelativeSource AncestorType={x:Type views:TestPage}}}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StartsideSectionCardStyle}">
                    <StackPanel>
                        <TextBlock FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{Binding DataContext.TopBarForeground, RelativeSource={RelativeSource AncestorType=Window}}"
                                   Text="IconGrid process overview" />
                        <TextBlock Margin="0,10,0,0"
                                   FontFamily="Consolas"
                                   TextWrapping="Wrap"
                                   Foreground="{Binding DataContext.SettingsSubtextForeground, RelativeSource={RelativeSource AncestorType=Window}}"
                                   Text="{Binding ProcessInfo, RelativeSource={RelativeSource AncestorType={x:Type views:TestPage}}}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StartsideSectionCardStyle}">
                    <StackPanel>
                        <TextBlock FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{Binding DataContext.TopBarForeground, RelativeSource={RelativeSource AncestorType=Window}}"
                                   Text="Startup diagnostics" />
                        <TextBlock Margin="0,10,0,0"
                                   FontFamily="Consolas"
                                   TextWrapping="Wrap"
                                   Foreground="{Binding DataContext.SettingsSubtextForeground, RelativeSource={RelativeSource AncestorType=Window}}"
                                   Text="{Binding StartupDiagnosticsInfo, RelativeSource={RelativeSource AncestorType={x:Type views:TestPage}}}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StartsideSectionCardStyle}">
                    <StackPanel>
                        <TextBlock FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{Binding DataContext.TopBarForeground, RelativeSource={RelativeSource AncestorType=Window}}"
                                   Text="Notes" />
                        <TextBlock Margin="0,10,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="{Binding DataContext.SettingsSubtextForeground, RelativeSource={RelativeSource AncestorType=Window}}"
                                   Text="If Windows startup creates a duplicate or elevated IconGrid instance again, check the Task Scheduler and legacy startup entries shown above before changing code." />
                    </StackPanel>
                </Border>
                </StackPanel>
            </views:TemplatePage.CardsContent>
        </views:TemplatePage>
    </ScrollViewer>
</UserControl>
