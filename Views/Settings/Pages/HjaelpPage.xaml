<UserControl x:Class="IconGrid.Views.HjaelpPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:helpers="clr-namespace:IconGrid.Helpers"
             xmlns:views="clr-namespace:IconGrid.Views"
             mc:Ignorable="d"
             Background="Transparent">
    <views:TemplatePage Margin="12">
        <views:TemplatePage.HeroContent>
            <StackPanel helpers:DevInspector.Metadata="Hjælp hero card → Views/HjaelpPage.xaml">
                <TextBlock Text="{Binding HelpTitleText}"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{Binding TopBarForeground}" />
                <TextBlock Text="{Binding HelpIntroText}"
                           FontSize="13"
                           Margin="0,8,0,0"
                           TextWrapping="Wrap"
                           Foreground="{Binding SettingsSubtextForeground}" />
            </StackPanel>
        </views:TemplatePage.HeroContent>
        <views:TemplatePage.CardsContent>
            <StackPanel>
                <Border Style="{StaticResource StartsideSectionCardStyle}"
                        helpers:DevInspector.Metadata="Drag &amp; drop info card → Views/HjaelpPage.xaml">
                    <TextBlock Text="{Binding HelpDragDropText}"
                               TextWrapping="Wrap"
                               Foreground="{Binding SettingsSubtextForeground}"
                               LineHeight="20" />
                </Border>
                <Border Style="{StaticResource StartsideSectionCardStyle}"
                        helpers:DevInspector.Metadata="Sensor info card → Views/HjaelpPage.xaml">
                    <TextBlock Text="{Binding HelpSensorsText}"
                               TextWrapping="Wrap"
                               Foreground="{Binding SettingsSubtextForeground}"
                               LineHeight="20" />
                </Border>
                <Border Style="{StaticResource StartsideSectionCardStyle}"
                        helpers:DevInspector.Metadata="More tips card → Views/HjaelpPage.xaml">
                    <TextBlock Text="{Binding HelpMoreTipsText}"
                               TextWrapping="Wrap"
                               Foreground="{Binding SettingsSubtextForeground}"
                               LineHeight="20" />
                </Border>
            </StackPanel>
        </views:TemplatePage.CardsContent>
    </views:TemplatePage>
</UserControl>
