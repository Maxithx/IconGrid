<UserControl x:Class="IconGrid.Views.GamingOverlayPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:helpers="clr-namespace:IconGrid.Helpers"
             xmlns:views="clr-namespace:IconGrid.Views"
             mc:Ignorable="d"
             Background="Transparent">
    <ScrollViewer Margin="12"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  CanContentScroll="False"
                  PanningMode="VerticalOnly">
        <ScrollViewer.Resources>
            <Style TargetType="ScrollBar" BasedOn="{StaticResource SettingsPageScrollBarStyle}" />
        </ScrollViewer.Resources>
        <views:TemplatePage Margin="0,0,8,0">
            <views:TemplatePage.HeroContent>
                <StackPanel helpers:DevInspector.Metadata="Gaming overlay hero card -> Views/GamingOverlayPage.xaml">
                    <TextBlock Text="Gaming overlay"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{Binding DataContext.TopBarForeground, RelativeSource={RelativeSource AncestorType=Window}}" />
                    <TextBlock Margin="0,8,0,0"
                               Text="Dedicated settings page for the gaming overlay. Keep this separate from the standard launcher settings."
                               TextWrapping="Wrap"
                               FontSize="13"
                               Foreground="{Binding DataContext.SettingsSubtextForeground, RelativeSource={RelativeSource AncestorType=Window}}" />
                    <Border Margin="0,16,0,0"
                            Padding="12"
                            CornerRadius="8"
                            Background="{Binding DataContext.SettingsCardBackground, RelativeSource={RelativeSource AncestorType=Window}}">
                        <StackPanel>
                            <TextBlock Text="Overlay scale"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding DataContext.TopBarForeground, RelativeSource={RelativeSource AncestorType=Window}}" />
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Slider Minimum="0.7"
                                        Maximum="1.2"
                                        TickFrequency="0.05"
                                        SmallChange="0.05"
                                        LargeChange="0.1"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding GamingOverlayUiScale, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Style="{StaticResource ModernSliderStyle}" />
                                <TextBlock Grid.Column="1"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{Binding DataContext.SettingsSubtextForeground, RelativeSource={RelativeSource AncestorType=Window}}"
                                           Text="{Binding GamingOverlayUiScale, StringFormat={}{0:P0}}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </views:TemplatePage.HeroContent>
            <views:TemplatePage.CardsContent>
                <StackPanel>
                    <Border Style="{StaticResource StartsideSectionCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Planned overlay settings"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding DataContext.TopBarForeground, RelativeSource={RelativeSource AncestorType=Window}}" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="Placeholder page for overlay-specific options."
                                       TextWrapping="Wrap"
                                       Foreground="{Binding DataContext.SettingsSubtextForeground, RelativeSource={RelativeSource AncestorType=Window}}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </views:TemplatePage.CardsContent>
        </views:TemplatePage>
    </ScrollViewer>
</UserControl>
