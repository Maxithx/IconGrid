<Window x:Class="IconGrid.Views.PawnIoWarningWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PawnIO required"
        Width="360"
        Height="180"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Topmost="True"
        ShowInTaskbar="False"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None">
    <Border Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
            CornerRadius="12"
            Padding="16"
            BorderBrush="#FF5F6368"
            BorderThickness="1">
        <StackPanel Margin="0">
            <TextBlock Name="MessageTextBlock"
                       Margin="0,0,0,4"
                       FontWeight="SemiBold"
                       FontSize="14"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" />
            <TextBlock Margin="0,0,0,4"
                       TextWrapping="Wrap"
                       Foreground="#FF6B7280"
                       FontSize="12">
                <Run Text="PawnIO is licensed under GPL-like terms. The installer runs the official " />
                <Hyperlink NavigateUri="https://pawnio.eu" RequestNavigate="LicenseLink_RequestNavigate">
                    PawnIO website
                </Hyperlink>
                <Run Text=" release so users can review the source and license before installing." />
            </TextBlock>
            <TextBlock Name="DownloadStatusTextBlock"
                       Margin="0,0,0,4"
                       FontSize="12"
                       Foreground="#FF1F2937"
                       Text="Ready to download."
                       TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,0,0,0">
                <Button x:Name="DownloadButton"
                        MinWidth="140"
                        Padding="8,4"
                        Margin="0,0,8,0"
                        Click="DownloadButton_Click"
                        Background="#FF2563EB"
                        Foreground="White"
                        BorderBrush="#FF1D4ED8">
                    Download and install PawnIO
                </Button>
                <Button MinWidth="90"
                        Padding="8,4"
                        Click="CloseButton_Click">
                    Luk
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
