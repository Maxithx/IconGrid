<Window x:Class="IconGrid.Views.MainWindow"
        x:Name="RootWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:IconGrid.Models"
        xmlns:helpers="clr-namespace:IconGrid.Helpers"
        xmlns:controls="clr-namespace:IconGrid.Controls"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="IconGrid"
        Height="66"
        Width="66"
        WindowStyle="None"
        ResizeMode="NoResize" 
        AllowsTransparency="True"
        Background="Transparent"
        SnapsToDevicePixels="False"
        UseLayoutRounding="False"
        Topmost="{Binding TopmostState}"
        AllowDrop="True"
        ShowInTaskbar="False"
        Icon="/Assets/dlb-icon.ico"
        Loaded="Window_Loaded"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseEnter="Window_MouseEnter"
        MouseLeave="Window_MouseLeave"
        DragOver="Window_DragOver"
        Drop="Window_Drop"
        Closing="Window_Closing"
        FontFamily="Segoe UI Variable"
        FontSize="{DynamicResource {x:Static SystemFonts.MessageFontSizeKey}}">
    <Window.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
        <helpers:InverseBoolConverter x:Key="InverseBoolConverter" />
        <helpers:SelectedTabMatchConverter x:Key="SelectedTabMatchConverter" />
        <helpers:ScrollButtonsVisibilityConverter x:Key="ScrollButtonsVisibilityConverter" />
        <helpers:TabNameLocalizationConverter x:Key="TabNameLocalizationConverter" />
        <helpers:PingSeverityToBrushConverter x:Key="PingSeverityBrush" />
        <helpers:PercentToHeightConverter x:Key="PercentToHeightConverter" />

        <Storyboard x:Key="SlideUpAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.25" />
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="20" To="0" Duration="0:0:0.35">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <SolidColorBrush x:Key="ForegroundLight" Color="#0F172A" />
        <SolidColorBrush x:Key="ForegroundDark" Color="#E5E5E5" />
        <SolidColorBrush x:Key="BorderLight" Color="#14000000" />
        <SolidColorBrush x:Key="BorderDark" Color="#1EFFFFFF" />
        
        <SolidColorBrush x:Key="ButtonHoverLight" Color="#E5E5E5" />
        <SolidColorBrush x:Key="ButtonPressLight" Color="#CCCCCC" />
        <SolidColorBrush x:Key="ButtonHoverDark" Color="#333333" />
        <SolidColorBrush x:Key="ButtonPressDark" Color="#444444" />
        <SolidColorBrush x:Key="TabHoverLight" Color="#19000000" />
        <SolidColorBrush x:Key="TabHoverLightBorder" Color="#22000000" />
        <SolidColorBrush x:Key="TabHoverDark" Color="#22FFFFFF" />
        <SolidColorBrush x:Key="TabHoverDarkBorder" Color="#30FFFFFF" />

        <!-- Default imaging: snap to device pixels and scale crisply -->
        <Style TargetType="Image">
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="UseLayoutRounding" Value="True" />
            <Setter Property="RenderOptions.BitmapScalingMode" Value="HighQuality" />
        </Style>

        <Style x:Key="MonitorTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsLightTheme, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                    <Setter Property="Foreground" Value="#111" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="NetworkMonitorTextStyle" TargetType="TextBlock" BasedOn="{StaticResource MonitorTextStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding SystemMonitor.IsHighPing}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource MonitorHighPingColor}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="MonitorValueStyle" TargetType="TextBlock" BasedOn="{StaticResource MonitorTextStyle}">
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="Width" Value="68" />
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="MonitorRowStyle" TargetType="StackPanel">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <SolidColorBrush x:Key="MonitorHighPingColor" Color="#FFF87171" />


        <Style x:Key="WindowControlButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground"
                    Value="{Binding DataContext.TopBarForeground, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue={StaticResource ForegroundLight}, TargetNullValue={StaticResource ForegroundLight}}" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1A000000" />
                                <Setter Property="Foreground" Value="#1F1F1F" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#33000000" />
                                <Setter Property="Foreground" Value="#111111" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsDarkTheme, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource ForegroundDark}" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="2">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#14FFFFFF" />
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#21FFFFFF" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WindowCloseButtonStyle" TargetType="Button" BasedOn="{StaticResource WindowControlButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123" />
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="0,8,0,0">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#C50F1F" />
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="0,8,0,0">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding DataContext.IsDarkTheme, RelativeSource={RelativeSource AncestorType=Window}}" Value="True" />
                        <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#E81123" />
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="0,8,0,0">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding DataContext.IsDarkTheme, RelativeSource={RelativeSource AncestorType=Window}}" Value="True" />
                        <Condition Binding="{Binding IsPressed, RelativeSource={RelativeSource Self}}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#C50F1F" />
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="0,8,0,0">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TabToggleStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground"
                    Value="{Binding DataContext.TopBarForeground, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue={StaticResource ForegroundLight}, TargetNullValue={StaticResource ForegroundLight}}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="MinWidth" Value="80" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="12,4" />
            <Setter Property="Margin" Value="4,0" />
            <Setter Property="ToolTipService.IsEnabled"
                    Value="{Binding DataContext.ShowDevOverlay, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBoolConverter}}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" 
                                SnapsToDevicePixels="True"
                                helpers:DevInspector.Metadata="{Binding DataContext, RelativeSource={RelativeSource AncestorType=RadioButton}, StringFormat=Tab: {0} (ViewModels/MainViewModel.cs)}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="0" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsChecked" Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="{StaticResource TabHoverLight}" />
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource TabHoverLightBorder}" />
                                <Setter TargetName="border" Property="BorderThickness" Value="1" />
                            </MultiTrigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{Binding DataContext.AccentBrush, RelativeSource={RelativeSource AncestorType=Window}}" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter TargetName="border" Property="BorderThickness" Value="0" />
                                <Setter TargetName="border" Property="BorderBrush" Value="Transparent" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="{Binding DataContext.AccentBrush, RelativeSource={RelativeSource AncestorType=Window}}" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter TargetName="border" Property="BorderThickness" Value="0" />
                                <Setter TargetName="border" Property="BorderBrush" Value="Transparent" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsDarkTheme, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                    <Setter Property="Template">
                        <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                                <Border x:Name="border"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="4" 
                                        SnapsToDevicePixels="True"
                                        helpers:DevInspector.Metadata="{Binding DataContext, RelativeSource={RelativeSource AncestorType=RadioButton}, StringFormat=Tab: {0} (ViewModels/MainViewModel.cs)}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Margin="0" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsMouseOver" Value="True" />
                                            <Condition Property="IsChecked" Value="False" />
                                        </MultiTrigger.Conditions>
                                        <Setter TargetName="border" Property="Background" Value="{StaticResource TabHoverDark}" />
                                        <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource TabHoverDarkBorder}" />
                                        <Setter TargetName="border" Property="BorderThickness" Value="1" />
                                    </MultiTrigger>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="{Binding DataContext.AccentBrush, RelativeSource={RelativeSource AncestorType=Window}}" />
                                        <Setter Property="Foreground" Value="White" />
                                        <Setter TargetName="border" Property="BorderThickness" Value="0" />
                                        <Setter TargetName="border" Property="BorderBrush" Value="Transparent" />
                                    </Trigger>
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsChecked" Value="True" />
                                            <Condition Property="IsMouseOver" Value="True" />
                                        </MultiTrigger.Conditions>
                                        <Setter TargetName="border" Property="Background" Value="{Binding DataContext.AccentBrush, RelativeSource={RelativeSource AncestorType=Window}}" />
                                        <Setter Property="Foreground" Value="White" />
                                        <Setter TargetName="border" Property="BorderThickness" Value="0" />
                                        <Setter TargetName="border" Property="BorderBrush" Value="Transparent" />
                                    </MultiTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LauncherIconTileStyle" TargetType="Button">
            <Setter Property="Padding" Value="8" />
            <Setter Property="Margin" Value="{Binding DataContext.IconMargin, RelativeSource={RelativeSource AncestorType=Window}}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <!-- Keep icon text white in all themes; outline/shadow in ShellIconTextBlock provides contrast -->
            <Setter Property="Foreground" Value="White" />
            <!-- Use Windows system font so text follows Windows 11 settings -->
            <Setter Property="FontFamily" Value="Segoe UI Variable" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Tile"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                Padding="{TemplateBinding Padding}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Border x:Name="IconContainer"
                                        Width="56"
                                        Height="56"
                                        CornerRadius="10"
                                        Background="Transparent"
                                        Padding="4"
                                        Margin="0,0,0,6"
                                        RenderTransformOrigin="0.5,0.5">
                                    <Border.LayoutTransform>
                                        <!-- Scale only the icon, not the text, when IconSize slider changes -->
                                        <ScaleTransform ScaleX="{Binding DataContext.EffectiveIconScale, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        ScaleY="{Binding DataContext.EffectiveIconScale, RelativeSource={RelativeSource AncestorType=Window}}" />
                                    </Border.LayoutTransform>
                                    <Border.RenderTransform>
                                        <ScaleTransform x:Name="HoverScaleTransform" ScaleX="1" ScaleY="1" />
                                    </Border.RenderTransform>
                                    <Image Stretch="Uniform"
                                           Source="{Binding IconImage}"
                                           Width="48"
                                           Height="48"
                                           RenderOptions.BitmapScalingMode="HighQuality"
                                           SnapsToDevicePixels="True"
                                           UseLayoutRounding="True" />
                                </Border>
                                  <Grid Width="130"
                                      Height="68"
                                      HorizontalAlignment="Center"
                                      ToolTip="{Binding DisplayName}">
                                    <!-- Four crisp offset shadows to outline all sides -->
                                    <TextBlock Text="{Binding DisplayName}"
                                               Foreground="#66000000"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center"
                                               FontFamily="Segoe UI Variable"
                                               FontSize="13"
                                               RenderOptions.BitmapScalingMode="HighQuality"
                                               SnapsToDevicePixels="True"
                                               UseLayoutRounding="True"
                                               Margin="1,1,0,0" />
                                    <TextBlock Text="{Binding DisplayName}"
                                               Foreground="#66000000"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center"
                                               FontFamily="Segoe UI Variable"
                                               FontSize="13"
                                               RenderOptions.BitmapScalingMode="HighQuality"
                                               SnapsToDevicePixels="True"
                                               UseLayoutRounding="True"
                                               Margin="-1,1,0,0" />
                                    <TextBlock Text="{Binding DisplayName}"
                                               Foreground="#66000000"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center"
                                               FontFamily="Segoe UI Variable"
                                               FontSize="13"
                                               RenderOptions.BitmapScalingMode="HighQuality"
                                               SnapsToDevicePixels="True"
                                               UseLayoutRounding="True"
                                               Margin="1,-1,0,0" />
                                    <TextBlock Text="{Binding DisplayName}"
                                               Foreground="#66000000"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center"
                                               FontFamily="Segoe UI Variable"
                                               FontSize="13"
                                               RenderOptions.BitmapScalingMode="HighQuality"
                                               SnapsToDevicePixels="True"
                                               UseLayoutRounding="True"
                                               Margin="-1,-1,0,0" />
                                    <TextBlock x:Name="IconLabel"
                                               Text="{Binding DisplayName}"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center"
                                               FontFamily="Segoe UI Variable"
                                               FontSize="13"
                                               RenderOptions.BitmapScalingMode="HighQuality"
                                               Foreground="White"
                                               SnapsToDevicePixels="True"
                                               UseLayoutRounding="True">
                                        <TextBlock.Effect>
                                            <!-- Subtle inner glow adds depth behind the white text -->
                                            <DropShadowEffect BlurRadius="0.5"
                                                              ShadowDepth="1.5"
                                                              Color="#09000000"
                                                              Opacity="0.5" />
                                        </TextBlock.Effect>
                                    </TextBlock>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="IconContainer" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.08" ScaleY="1.08" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="IconContainer" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.0" ScaleY="1.0" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource ForegroundLight}" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F3F3F3" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#D7DCE3" />
                                <Setter TargetName="border" Property="BorderThickness" Value="1" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E0E0E0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsDarkTheme, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource ForegroundDark}" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        BorderThickness="0"
                                        CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#444444" />
                                        <Setter TargetName="border" Property="BorderBrush" Value="#383838" />
                                        <Setter TargetName="border" Property="BorderThickness" Value="1" />
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#555555" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>
    <Grid x:Name="RootLayoutGrid"
          helpers:DevInspector.Metadata="Root layout container → Views/MainWindow.xaml">
        <Grid x:Name="FloatingIconHost"
              Visibility="{Binding IsFullWindowVisible, Converter={StaticResource InverseBoolToVisibilityConverter}}">
            <Button x:Name="FloatingIconButton"
                    Width="66"
                    Height="66"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,12,12"
                    Padding="0"
                    BorderThickness="0"
                    Background="Transparent"
                    PreviewMouseLeftButtonDown="FloatingIconButton_PreviewMouseLeftButtonDown"
                    PreviewMouseMove="FloatingIconButton_PreviewMouseMove"
                    PreviewMouseLeftButtonUp="FloatingIconButton_PreviewMouseLeftButtonUp"
                    ToolTip="Open IconGrid">
                <Button.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Luk programmet helt" Click="FloatingIconExitMenuItem_Click" />
                    </ContextMenu>
                </Button.ContextMenu>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent"
                                Padding="9">
                            <Border Width="48"
                                    Height="48"
                                    CornerRadius="12"
                                    Background="{Binding DataContext.AccentBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                                    SnapsToDevicePixels="True"
                                    UseLayoutRounding="True">
                                <UniformGrid Rows="3" Columns="3" Margin="6" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Ellipse Fill="White" Width="8" Height="8" />
                                    <Ellipse Fill="White" Width="8" Height="8" />
                                    <Ellipse Fill="White" Width="8" Height="8" />
                                    <Ellipse Fill="White" Width="8" Height="8" />
                                    <Ellipse Fill="White" Width="8" Height="8" />
                                    <Ellipse Fill="White" Width="8" Height="8" />
                                    <Ellipse Fill="White" Width="8" Height="8" />
                                    <Ellipse Fill="White" Width="8" Height="8" />
                                    <Ellipse Fill="White" Width="8" Height="8" />
                                </UniformGrid>
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <Grid x:Name="FullUiHost"
              Visibility="{Binding IsFullWindowVisible, Converter={StaticResource BoolToVisibilityConverter}}"
              Margin="0"
              HorizontalAlignment="Center"
              VerticalAlignment="Top">
            <Border HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0"
                Padding="0"
                Background="Transparent"
                CornerRadius="8,8,6,6"
                BorderThickness="1"
                BorderBrush="#333333"
                Width="{Binding ContentWidth}"
                MinWidth="{Binding ContentMinWidth}"
                MaxWidth="{Binding ContentMaxWidth}"
                Height="Auto"
                UseLayoutRounding="False"
                SnapsToDevicePixels="False"
                ClipToBounds="True">
                <Border.LayoutTransform>
                    <ScaleTransform ScaleX="{Binding UiScale}" ScaleY="{Binding UiScale}" />
                </Border.LayoutTransform>
                <!-- No LayoutTransform - disabled scaling via UiScale -->

            <Grid Margin="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border x:Name="TopBarBackground" 
                        Grid.Row="0" Grid.RowSpan="2" 
                        Background="{Binding DataContext.TopBarBackground, RelativeSource={RelativeSource AncestorType=Window}}" 
                        CornerRadius="8,8,0,0"
                        Margin="0" />

                <Grid x:Name="TopBarGrid" Grid.Row="0" Background="Transparent" Height="Auto" VerticalAlignment="Top" UseLayoutRounding="False" SnapsToDevicePixels="False" Margin="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="8,4,0,4" VerticalAlignment="Center">
                        <Button x:Name="LogoButton"
                                helpers:DevInspector.Metadata="IconGrid logo button → Views/MainWindow.xaml (LogoButton_Click)"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Click="LogoButton_Click"
                                ToolTip="{Binding LayoutPresetToolTip}"
                                Focusable="False"
                                FocusVisualStyle="{x:Null}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <ContentPresenter HorizontalAlignment="Left"
                                                      VerticalAlignment="Center" />
                                </ControlTemplate>
                            </Button.Template>
                            <Button.ContextMenu>
                                <ContextMenu Opened="LayoutContextMenu_Opened" />
                            </Button.ContextMenu>
                            <controls:LauncherLogo Width="24"
                                                   Height="24"
                                                   AccentBrush="{Binding DataContext.AccentBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   SnapsToDevicePixels="True"
                                                   helpers:DevInspector.Metadata="IconGrid logo graphic → Views/MainWindow.xaml (LogoButton_Click)" />
                        </Button>
                        <TextBlock Text="IconGrid"
                                   Margin="8,0,0,0"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Foreground="{Binding DataContext.TopBarForeground, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue={StaticResource ForegroundLight}, TargetNullValue={StaticResource ForegroundLight}}"
                                   helpers:DevInspector.Metadata="IconGrid title text → Views/MainWindow.xaml" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="8,0"
                        helpers:DevInspector.Metadata="Monitor row → Helpers/SystemMonitor.cs (SystemMonitor values)">
                        <Border Width="10" Height="10" CornerRadius="5"
                                VerticalAlignment="Center"
                                Margin="0,0,6,0"
                                Background="{Binding SystemMonitor.PingSeverityLevel, Converter={StaticResource PingSeverityBrush}}" />
                        <TextBlock Style="{StaticResource NetworkMonitorTextStyle}"
                                   Margin="0,0,0,0"
                                   MinWidth="70"
                                   ToolTipService.IsEnabled="{Binding DataContext.ShowDevOverlay, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBoolConverter}}">
                            <Run Text="{Binding MonitorNetworkLabel, Mode=OneWay}" />
                            <Run Text=": " />
                            <Run Text="{Binding SystemMonitor.NetworkStatus, Mode=OneWay}" />
                        </TextBlock>
                        <TextBlock Style="{StaticResource MonitorTextStyle}"
                                   Margin="4,0,0,0"
                                   MinWidth="80"
                                   ToolTipService.IsEnabled="{Binding DataContext.ShowDevOverlay, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBoolConverter}}">
                            <Run Text="{Binding MonitorDownloadLabel, Mode=OneWay}" />
                            <Run Text=": " />
                            <Run FontFamily="Consolas" Text="{Binding SystemMonitor.DownloadStatus, Mode=OneWay}" />
                        </TextBlock>
                        <TextBlock Style="{StaticResource MonitorTextStyle}"
                                   Margin="4,0,0,0"
                                   MinWidth="80"
                                   ToolTipService.IsEnabled="{Binding DataContext.ShowDevOverlay, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBoolConverter}}">
                            <Run Text="{Binding MonitorUploadLabel, Mode=OneWay}" />
                            <Run Text=": " />
                            <Run FontFamily="Consolas" Text="{Binding SystemMonitor.UploadStatus, Mode=OneWay}" />
                        </TextBlock>
                        <TextBlock Style="{StaticResource MonitorTextStyle}"
                                   Margin="0,0,12,0"
                                   Width="75"
                                   TextAlignment="Right"
                                   ToolTipService.IsEnabled="{Binding DataContext.ShowDevOverlay, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBoolConverter}}">
                            <Run Text="{Binding MonitorCpuLabel, Mode=OneWay}" />
                            <Run Text=": " />
                            <Run Text="{Binding SystemMonitor.CpuTemp, Mode=OneWay}" />
                        </TextBlock>
                        <Border Width="12"
                                Height="14"
                                Margin="0,0,10,0"
                                Background="#22000000"
                                BorderBrush="#80FFFFFF"
                                BorderThickness="1"
                                CornerRadius="2"
                                ToolTip="{Binding SystemMonitor.CpuUsage}">
                            <Rectangle Fill="#22C55E"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Bottom"
                                       RadiusX="2" RadiusY="2"
                                       Height="{Binding SystemMonitor.CpuUsagePercent, Converter={StaticResource PercentToHeightConverter}, ConverterParameter=12}" />
                        </Border>
                        <TextBlock Style="{StaticResource MonitorTextStyle}"
                                   Width="64"
                                   Margin="2,0,0,0"
                                   TextAlignment="Right"
                                   ToolTipService.IsEnabled="{Binding DataContext.ShowDevOverlay, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBoolConverter}}">
                            <Run Text="{Binding MonitorGpuLabel, Mode=OneWay}" />
                            <Run Text=": " />
                            <Run Text="{Binding SystemMonitor.GpuTemp, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>

                    <Button Grid.Column="2" Style="{StaticResource WindowControlButtonStyle}" Click="MinimizeButton_Click" ToolTip="Minimize" Width="44" Height="32" Padding="0" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="4,0,0,0">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE921;" FontSize="12" VerticalAlignment="Center" Foreground="{Binding DataContext.TopBarForeground, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue={StaticResource ForegroundLight}, TargetNullValue={StaticResource ForegroundLight}}" />
                    </Button>
                    <Button Grid.Column="3" Style="{StaticResource WindowCloseButtonStyle}" Click="CloseButton_Click" ToolTip="Close" Width="44" Height="32" Padding="0" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="4,0,0,0">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8BB;" FontSize="12" VerticalAlignment="Center" Foreground="{Binding DataContext.TopBarForeground, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue={StaticResource ForegroundLight}, TargetNullValue={StaticResource ForegroundLight}}" />
                    </Button>
                </Grid>

                <Border x:Name="TabsBorder" Grid.Row="1" Background="Transparent"
                        CornerRadius="0"
                        Padding="8,6"
                        BorderBrush="{StaticResource BorderLight}"
                        BorderThickness="0,0,0,1"
                        Margin="0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.IsDarkTheme, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderDark}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                   
                    <Grid Margin="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0" Margin="0"
                          helpers:DevInspector.Metadata="Tab navigation host → Views/MainWindow.xaml (Tabs controls)">
                        <ScrollViewer x:Name="TabsScrollViewer"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Disabled"
                                      Margin="0"
                                      helpers:DevInspector.Metadata="Tabs scroll area → Views/MainWindow.xaml (Tabs controls)">
                                <ItemsControl ItemsSource="{Binding Tabs}"
                                              helpers:DevInspector.Metadata="Tabs items host → Views/MainWindow.xaml (Tabs controls)">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <RadioButton Margin="4,0"
                                                         Style="{StaticResource TabToggleStyle}"
                                                         Command="{Binding DataContext.SelectTabCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                         CommandParameter="{Binding}"
                                                         Click="TabToggle_Click"
                                                         helpers:DevInspector.Metadata="{Binding ., StringFormat=Tab: {0} (ViewModels/MainViewModel.cs)}">
                                                <RadioButton.ContextMenu>
                                                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                        <MenuItem Header="Rename tab" Click="RenameTabMenuItem_Click" />
                                                        <MenuItem Header="Remove tab" Click="RemoveTabMenuItem_Click" />
                                                    </ContextMenu>
                                                </RadioButton.ContextMenu>
                                                <RadioButton.IsChecked>
                                                    <MultiBinding Converter="{StaticResource SelectedTabMatchConverter}" Mode="OneWay">
                                                        <Binding />
                                                        <Binding Path="DataContext.SelectedTab"
                                                             RelativeSource="{RelativeSource AncestorType=Window}" />
                                                    </MultiBinding>
                                                </RadioButton.IsChecked>
                                                <ContentPresenter>
                                                    <ContentPresenter.Content>
                                                        <MultiBinding Converter="{StaticResource TabNameLocalizationConverter}" Mode="OneWay">
                                                            <Binding />
                                                            <Binding Path="DataContext.Language" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                        </MultiBinding>
                                                    </ContentPresenter.Content>
                                                </ContentPresenter>
                                            </RadioButton>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,8,0"
                                    helpers:DevInspector.Metadata="Tab scroll controls → Views/MainWindow.xaml (Tabs controls)">
                            <Button Style="{StaticResource IconButtonStyle}"
                                    Click="ScrollTabsLeft_Click"
                                    ToolTip="Scroll left"
                                    Margin="0,0,8,0"
                                    Width="28" Height="28" Padding="0" VerticalAlignment="Center"
                                    helpers:DevInspector.Metadata="Scroll tabs left button → Views/MainWindow.xaml (ScrollTabsLeft_Click)">
                                <Button.Visibility>
                                    <MultiBinding Converter="{StaticResource ScrollButtonsVisibilityConverter}" ConverterParameter="6">
                                        <Binding Path="ShowScrollButtons" />
                                        <Binding Path="Tabs.Count" />
                                    </MultiBinding>
                                </Button.Visibility>
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE76B;" FontSize="13" VerticalAlignment="Center" />
                            </Button>
                            <Button Style="{StaticResource IconButtonStyle}"
                                    Click="ScrollTabsRight_Click"
                                    ToolTip="Scroll right"
                                    Width="28" Height="28" Padding="0" VerticalAlignment="Center"
                                    helpers:DevInspector.Metadata="Scroll tabs right button → Views/MainWindow.xaml (ScrollTabsRight_Click)">
                                <Button.Visibility>
                                    <MultiBinding Converter="{StaticResource ScrollButtonsVisibilityConverter}" ConverterParameter="6">
                                        <Binding Path="ShowScrollButtons" />
                                        <Binding Path="Tabs.Count" />
                                    </MultiBinding>
                                </Button.Visibility>
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE76C;" FontSize="13" VerticalAlignment="Center" />
                            </Button>
                        </StackPanel>
                        <Button Grid.Column="2"
                            Content="+"
                            Style="{StaticResource IconButtonStyle}"
                            Click="AddTabButton_Click"
                            Margin="0,0,4,0"
                            Width="28" Height="28" Padding="0" VerticalAlignment="Center"
                            helpers:DevInspector.Metadata="Add tab button → MainViewModel.AddTab" />
                        <Button Grid.Column="3"
                            Style="{StaticResource IconButtonStyle}"
                            Click="MoreButton_Click"
                            ToolTip="More"
                            Margin="4,0,16,0"
                            Width="28" Height="28" Padding="0" VerticalAlignment="Center"
                            helpers:DevInspector.Metadata="More menu button → Views/MainWindow.xaml (MoreButton_Click)">
                            <TextBlock Text="&#xE712;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </Button>
                    </Grid>
                </Border>

                        <Grid Grid.Row="2" x:Name="IconAreaGrid"
                              helpers:DevInspector.Metadata="Icon grid content area → Views/MainWindow.xaml">
                    <Grid.RenderTransform>
                        <TranslateTransform Y="0" />
                    </Grid.RenderTransform>
                    <Grid Visibility="{Binding IsOverlayOpen, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <Border Margin="0"
                        Padding="20,26,20,0"
                        Background="#33FFFFFF"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        CornerRadius="0,0,8,8"
                        Width="{Binding ContentWidth}"
                        Height="{Binding ContentHostHeight}"
                        MaxHeight="{Binding ContentHostHeight}"
                        AllowDrop="True"
                        UseLayoutRounding="True"
                        SnapsToDevicePixels="True"
                        DragOver="ItemsControl_DragOver"
                        Drop="ItemsControl_Drop"
                        ContextMenuOpening="ContentArea_ContextMenuOpening">
                            <Grid>
                                <TextBlock Text="Træk og Slip en genvej her"
                                        Foreground="#66FFFFFF"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentItems.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                    <ScrollViewer x:Name="IconScrollViewer"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  PanningMode="VerticalOnly"
                                                  CanContentScroll="True"
                                                  Padding="0,0,0,0"
                                                  ScrollChanged="IconScrollViewer_ScrollChanged">
                                        <ScrollViewer.Style>
                                            <Style TargetType="ScrollViewer">
                                                <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.EnableContentScroll, ElementName=RootWindow}" Value="False">
                                                        <Setter Property="VerticalScrollBarVisibility" Value="Hidden" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ScrollViewer.Style>
                                        <ScrollViewer.Resources>
                                        <!-- WinUI-like slim vertical scrollbar -->
                                        <Style TargetType="ScrollBar">
                                            <Setter Property="Width" Value="4" />
                                            <Setter Property="Foreground" Value="#AAFFFFFF" />
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ScrollBar">
                                                        <Grid x:Name="GridRoot"
                                                              Background="Transparent"
                                                              SnapsToDevicePixels="True">
                                                            <Border x:Name="TrackBackground"
                                                                    Background="#22000000"
                                                                    CornerRadius="2"
                                                                    Margin="1,4,1,4"
                                                                    Opacity="0" />
                                                            <Track x:Name="PART_Track"
                                                                   IsDirectionReversed="true">
                                                                <Track.DecreaseRepeatButton>
                                                                    <RepeatButton Command="ScrollBar.LineUpCommand"
                                                                                  Style="{x:Null}"
                                                                                  Template="{x:Null}" />
                                                                </Track.DecreaseRepeatButton>
                                                                <Track.IncreaseRepeatButton>
                                                                    <RepeatButton Command="ScrollBar.LineDownCommand"
                                                                                  Style="{x:Null}"
                                                                                  Template="{x:Null}" />
                                                                </Track.IncreaseRepeatButton>
                                                                <Track.Thumb>
                                                                    <Thumb x:Name="Thumb"
                                                                           Background="#AAFFFFFF"
                                                                           Opacity="0.65">
                                                                        <Thumb.Template>
                                                                            <ControlTemplate TargetType="Thumb">
                                                                                <Border Background="{TemplateBinding Background}"
                                                                                        CornerRadius="2" />
                                                                            </ControlTemplate>
                                                                        </Thumb.Template>
                                                                    </Thumb>
                                                                </Track.Thumb>
                                                            </Track>
                                                        </Grid>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="TrackBackground" Property="Opacity" Value="0.5" />
                                                                <Setter TargetName="Thumb" Property="Opacity" Value="0.9" />
                                                            </Trigger>
                                                            <Trigger Property="IsEnabled" Value="False">
                                                                <Setter TargetName="Thumb" Property="Opacity" Value="0" />
                                                                <Setter TargetName="TrackBackground" Property="Opacity" Value="0" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ScrollViewer.Resources>
                                    <ItemsControl ItemsSource="{Binding CurrentItems}"
                                                  AllowDrop="True"
                                                  DragOver="ItemsControl_DragOver"
                                                  Drop="ItemsControl_Drop"
                                                  VerticalAlignment="Top">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="{Binding IconsPerRow}" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="HorizontalAlignment" Value="Center" />
                                                <Setter Property="VerticalAlignment" Value="Top" />
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type models:LauncherItem}">
                                                <Button Style="{StaticResource LauncherIconTileStyle}"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Top"
                                                        MouseDoubleClick="LauncherItemButton_MouseDoubleClick"
                                                        PreviewMouseLeftButtonDown="LauncherItem_PreviewMouseLeftButtonDown"
                                                        PreviewMouseMove="LauncherItem_PreviewMouseMove"
                                                        DragOver="LauncherItem_DragOver"
                                                        Drop="LauncherItem_Drop"
                                                        AllowDrop="True">
                                                    <Button.ContextMenu>
                                                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                            <MenuItem Header="{Binding DataContext.OpenLabel, Source={x:Reference RootWindow}}" Click="OpenItemMenuItem_Click" />
                                                            <MenuItem Header="{Binding DataContext.RunAsAdminLabel, Source={x:Reference RootWindow}}" Click="RunAsAdminMenuItem_Click" />
                                                            <MenuItem Header="{Binding DataContext.OpenFileLocationLabel, Source={x:Reference RootWindow}}" Click="OpenLocationMenuItem_Click" />
                                                            <MenuItem Header="{Binding DataContext.CopyPathLabel, Source={x:Reference RootWindow}}" Click="CopyPathMenuItem_Click" />
                                                            <MenuItem Header="{Binding DataContext.ChangeIconLabel, Source={x:Reference RootWindow}}">
                                                                <MenuItem Header="{Binding DataContext.WindowsIconsLabel, Source={x:Reference RootWindow}}"
                                                                          Tag="%SystemRoot%\\System32\\imageres.dll"
                                                                          Click="ChangeIconMenuItem_Click" />
                                                            </MenuItem>
                                                            <MenuItem Header="{Binding DataContext.ResetIconLabel, Source={x:Reference RootWindow}}" Click="ResetIconMenuItem_Click" />
                                                            <Separator />
                                                            <MenuItem Header="{Binding DataContext.RenameLabel, Source={x:Reference RootWindow}}" Click="RenameMenuItem_Click" />
                                                            <MenuItem Header="{Binding DataContext.RemoveLabel, Source={x:Reference RootWindow}}" Click="RemoveItemMenuItem_Click" />
                                                        </ContextMenu>
                                                    </Button.ContextMenu>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                            </Grid>
                        </Border>
                    </Grid>
                    <Grid Visibility="{Binding IsSettingsOpen, Converter={StaticResource BoolToVisibilityConverter}}"
                          Background="#FFF3F3F3"
                          helpers:DevInspector.Metadata="Settings overlay root → Views/MainWindow.xaml (Settings controls)">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      CanContentScroll="True"
                                      helpers:DevInspector.Metadata="Settings overlay scroller → Views/MainWindow.xaml (Settings controls)">
                            <StackPanel Margin="24"
                                        Orientation="Vertical"
                                        HorizontalAlignment="Stretch"
                                        helpers:DevInspector.Metadata="Settings stack → Views/MainWindow.xaml (Settings controls)">
                                <TextBlock Text="{Binding SettingsTitle}"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8"
                                           helpers:DevInspector.Metadata="Settings title → Views/MainWindow.xaml (Settings controls)" />
                                <TextBlock Text="{Binding IconsPerRowLabel}"
                                           FontSize="12"
                                           Margin="0,12,0,0"
                                           helpers:DevInspector.Metadata="Icons per row label → Views/MainWindow.xaml (Settings controls)" />
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                            helpers:DevInspector.Metadata="Icons per row slider row → Views/MainWindow.xaml (Settings controls)">
                                    <Slider Minimum="4"
                                            Maximum="8"
                                            SmallChange="1"
                                            LargeChange="1"
                                            TickFrequency="1"
                                            IsSnapToTickEnabled="True"
                                            Width="240"
                                            Value="{Binding IconsPerRow, Mode=TwoWay}" />
                                    <TextBlock Text="{Binding IconsPerRow, StringFormat=' {0}'}"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               helpers:DevInspector.Metadata="Icons per row value → Views/MainWindow.xaml (Settings controls)" />
                                </StackPanel>
                                <TextBlock Text="{Binding IconRowSpacingLabel}"
                                           FontSize="12"
                                           Margin="0,12,0,0"
                                           helpers:DevInspector.Metadata="Icon row spacing label → Views/MainWindow.xaml (Settings controls)" />
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                            helpers:DevInspector.Metadata="Icon row spacing slider row → Views/MainWindow.xaml (Settings controls)">
                                    <Slider Minimum="-40"
                                            Maximum="32"
                                            SmallChange="1"
                                            LargeChange="2"
                                            TickFrequency="1"
                                            IsSnapToTickEnabled="True"
                                            Width="240"
                                            Value="{Binding IconRowSpacing, Mode=TwoWay}" />
                                    <TextBlock Text="{Binding IconRowSpacing, StringFormat=' {0:F0} px'}"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               helpers:DevInspector.Metadata="Icon row spacing value → Views/MainWindow.xaml (Settings controls)" />
                                </StackPanel>
                                <TextBlock Text="{Binding LastRowPaddingLabel}"
                                           FontSize="12"
                                           Margin="0,12,0,0"
                                           helpers:DevInspector.Metadata="Last row padding label → Views/MainWindow.xaml (Settings controls)" />
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                            helpers:DevInspector.Metadata="Last row padding slider row → Views/MainWindow.xaml (Settings controls)">
                                    <Slider Minimum="-80"
                                            Maximum="80"
                                            SmallChange="1"
                                            LargeChange="5"
                                            TickFrequency="5"
                                            IsSnapToTickEnabled="True"
                                            Width="240"
                                            Value="{Binding LastRowPaddingAdjust, Mode=TwoWay}" />
                                    <TextBlock Text="{Binding LastRowPaddingAdjust, StringFormat=' {0:F0} px'}"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               helpers:DevInspector.Metadata="Last row padding value → Views/MainWindow.xaml (Settings controls)" />
                                </StackPanel>
                                <TextBlock Text="{Binding IconSizeLabel}"
                                           FontSize="12"
                                           Margin="0,12,0,0"
                                           helpers:DevInspector.Metadata="Icon size label → Views/MainWindow.xaml (Settings controls)" />
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                            helpers:DevInspector.Metadata="Icon size slider row → Views/MainWindow.xaml (Settings controls)">
                                    <Slider Minimum="0.8"
                                            Maximum="1.5"
                                            SmallChange="0.05"
                                            LargeChange="0.1"
                                            TickFrequency="0.05"
                                            IsSnapToTickEnabled="True"
                                            Width="240"
                                            Value="{Binding IconScale, Mode=TwoWay}" />
                                    <TextBlock Text="{Binding IconScale, StringFormat=' {0:P0}'}"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               helpers:DevInspector.Metadata="Icon scale value → Views/MainWindow.xaml (Settings controls)" />
                                </StackPanel>
                                <TextBlock Text="{Binding UiScaleLabel}"
                                           FontSize="12"
                                           Margin="0,12,0,0"
                                           helpers:DevInspector.Metadata="UI scale label → Views/MainWindow.xaml (Settings controls)" />
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                            helpers:DevInspector.Metadata="UI scale slider row → Views/MainWindow.xaml (Settings controls)">
                                    <Slider Minimum="0.8"
                                            Maximum="1.0"
                                            SmallChange="0.02"
                                            LargeChange="0.05"
                                            TickFrequency="0.02"
                                            IsSnapToTickEnabled="True"
                                            Width="240"
                                            Value="{Binding UiScale, Mode=TwoWay}" />
                                    <TextBlock Text="{Binding UiScale, StringFormat=' {0:P0}'}"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               helpers:DevInspector.Metadata="UI scale value → Views/MainWindow.xaml (Settings controls)" />
                                </StackPanel>
                                <CheckBox Content="{Binding AlwaysOnTopLabel}"
                                          Margin="0,12,0,0"
                                          helpers:DevInspector.Metadata="Always on top checkbox → MainViewModel.IsAlwaysOnTop"
                                          IsChecked="{Binding IsAlwaysOnTop, Mode=TwoWay}" />
                                <CheckBox Content="{Binding FloatingIconTopmostLabel}"
                                          Margin="0,8,0,0"
                                          helpers:DevInspector.Metadata="Floating icon topmost checkbox → MainViewModel.IsFloatingIconTopmost"
                                          IsChecked="{Binding IsFloatingIconTopmost, Mode=TwoWay}" />
                                <CheckBox Content="{Binding ShowScrollButtonsLabel}"
                                          Margin="0,8,0,0"
                                          helpers:DevInspector.Metadata="Scroll buttons checkbox → MainViewModel.ShowScrollButtons"
                                          IsChecked="{Binding ShowScrollButtons, Mode=TwoWay}" />
                                <CheckBox Content="{Binding ShowDesktopIconLabel}"
                                          Margin="0,8,0,0"
                                          helpers:DevInspector.Metadata="Desktop icon checkbox → MainViewModel.ShowDesktopIcon"
                                          IsChecked="{Binding ShowDesktopIcon, Mode=TwoWay}" />
                                <CheckBox Content="{Binding StartWithWindowsLabel}"
                                          Margin="0,8,0,0"
                                          helpers:DevInspector.Metadata="Start with Windows checkbox → MainViewModel.StartWithWindows"
                                          IsChecked="{Binding StartWithWindows, Mode=TwoWay}" />
                                <CheckBox Content="{Binding DevOverlayLabel}"
                                          Margin="0,8,0,0"
                                          helpers:DevInspector.Metadata="Dev overlay checkbox → MainViewModel.ShowDevOverlay"
                                          IsChecked="{Binding ShowDevOverlay, Mode=TwoWay}" />
                                <CheckBox Content="{Binding EnableSlideUpAnimationLabel}"
                                          Margin="0,8,0,0"
                                          helpers:DevInspector.Metadata="Slide up animation checkbox → MainViewModel.EnableSlideUpAnimation"
                                          IsChecked="{Binding EnableSlideUpAnimation, Mode=TwoWay}" />
                                <TextBlock Text="{Binding WindowAnimationSpeedLabel}"
                                           FontSize="12"
                                           Margin="0,12,0,0"
                                           helpers:DevInspector.Metadata="Window animation label → Views/MainWindow.xaml (Settings controls)" />
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                            helpers:DevInspector.Metadata="Window animation slider row → Views/MainWindow.xaml (Settings controls)">
                                    <Slider Minimum="0"
                                            Maximum="1000"
                                            SmallChange="10"
                                            LargeChange="100"
                                            TickFrequency="50"
                                            IsSnapToTickEnabled="True"
                                            Width="240"
                                            Value="{Binding WindowAnimationDurationMs, Mode=TwoWay}" />
                                    <TextBlock Text="{Binding WindowAnimationDurationMs, StringFormat=' {0} ms'}"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               helpers:DevInspector.Metadata="Window animation value → Views/MainWindow.xaml (Settings controls)" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0"
                                            helpers:DevInspector.Metadata="Reset defaults row → Views/MainWindow.xaml (Settings controls)">
                                    <Button Content="{Binding ResetDefaultsLabel}"
                                            Padding="12,6"
                                            helpers:DevInspector.Metadata="Reset defaults button → MainViewModel.ResetSettingsCommand"
                                            Command="{Binding ResetSettingsCommand}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,12,0,24"
                                            VerticalAlignment="Center"
                                            helpers:DevInspector.Metadata="Language selection row → Views/MainWindow.xaml (Settings controls)">
                                    <TextBlock Text="{Binding LanguageLabel}"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               Margin="0,0,12,0"
                                               helpers:DevInspector.Metadata="Language label → Views/MainWindow.xaml (Settings controls)" />
                                    <ComboBox Width="200"
                                              SelectedValuePath="Tag"
                                              SelectedValue="{Binding Language, Mode=TwoWay}"
                                              helpers:DevInspector.Metadata="Language selector → Views/MainWindow.xaml (Settings controls)">
                                        <ComboBoxItem Content="English" Tag="en" />
                                        <ComboBoxItem Content="Dansk" Tag="da" />
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                    <Grid Visibility="{Binding IsLayoutsOpen, Converter={StaticResource BoolToVisibilityConverter}}"
                          Background="#FFF3F3F3"
                          helpers:DevInspector.Metadata="Layouts overlay root → Views/MainWindow.xaml (Layouts controls)">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto"
                                      CanContentScroll="True"
                                      helpers:DevInspector.Metadata="Layouts overlay scroller → Views/MainWindow.xaml (Layouts controls)">
                            <StackPanel Margin="24"
                                        VerticalAlignment="Top"
                                        Orientation="Vertical"
                                        HorizontalAlignment="Stretch"
                                        MinWidth="1300"
                                        MaxWidth="1700"
                                        MinHeight="{Binding ContentHostHeight}"
                                        Height="{Binding ContentHostHeight}"
                                        helpers:DevInspector.Metadata="Layouts overlay stack → Views/MainWindow.xaml (Layouts controls)">
                                <TextBlock Text="Layouts"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8"
                                           helpers:DevInspector.Metadata="Layouts title → Views/MainWindow.xaml (Layouts controls)" />
                                <TextBlock Text="Vælg et layout til hurtig omrokering af åbne vinduer."
                                           FontSize="12"
                                           Margin="0,0,0,12"
                                           helpers:DevInspector.Metadata="Layouts subtitle → Views/MainWindow.xaml (Layouts controls)" />
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0" VerticalAlignment="Center"
                                            helpers:DevInspector.Metadata="Standard layout row → Views/MainWindow.xaml (Layouts controls)">
                                    <TextBlock Text="Standard layout"
                                               FontSize="12"
                                               Margin="0,0,12,0"
                                               VerticalAlignment="Center"
                                               helpers:DevInspector.Metadata="Standard layout label → Views/MainWindow.xaml (Layouts controls)" />
                                    <Button x:Name="LayoutPresetButton"
                                            Width="240"
                                            helpers:DevInspector.Metadata="Layouts preset picker → MainViewModel.LayoutPreset"
                                            HorizontalContentAlignment="Stretch"
                                            Padding="8,4"
                                            Click="LayoutPresetButton_Click">
                                        <Button.ContextMenu>
                                            <ContextMenu Opened="LayoutsPageMenu_Opened" />
                                        </Button.ContextMenu>
                                        <Grid>
                                            <TextBlock Text="{Binding LayoutPreset}" VerticalAlignment="Center" FontWeight="Normal" />
                                            <TextBlock Text="&#xE70D;" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                                        </Grid>
                                    </Button>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0" VerticalAlignment="Center"
                                            helpers:DevInspector.Metadata="Save layout row → Views/MainWindow.xaml (Layouts controls)">
                                    <Button Content="Gem nuværende opstilling som..."
                                            Padding="12,6"
                                            helpers:DevInspector.Metadata="Save layout button → MainViewModel.SaveLayoutAsCommand"
                                            Click="SaveLayoutAsButton_Click" />
                                </StackPanel>
                                <CheckBox Content="Spring minimerede vinduer over"
                                          Margin="0,12,0,0"
                                          helpers:DevInspector.Metadata="Skip minimized checkbox → MainViewModel.LayoutSkipMinimized"
                                          IsChecked="{Binding LayoutSkipMinimized, Mode=TwoWay}" />
                                <CheckBox Content="Brug kun den aktive skærm"
                                          Margin="0,6,0,0"
                                          helpers:DevInspector.Metadata="Active screen checkbox → MainViewModel.LayoutCurrentMonitorOnly"
                                          IsChecked="{Binding LayoutCurrentMonitorOnly, Mode=TwoWay}" />
                                <StackPanel Orientation="Horizontal" Margin="0,16,0,0"
                                            helpers:DevInspector.Metadata="Layout action buttons → Views/MainWindow.xaml (Layouts controls)">
                                    <Button Content="Kør layout nu"
                                            Padding="12,6"
                                            helpers:DevInspector.Metadata="Run layout button → Views/MainWindow.xaml (ArrangeNowButton_Click)"
                                            Click="ArrangeNowButton_Click" />
                                    <Button Content="Luk"
                                            Padding="12,6"
                                            Margin="8,0,0,0"
                                            helpers:DevInspector.Metadata="Close layouts button → Views/MainWindow.xaml (CloseLayoutsButton_Click)"
                                            Click="CloseLayoutsButton_Click" />
                                </StackPanel>
                                <TextBlock Text="Tip: Layoutet vælges ud fra hvor mange vinduer der er synlige."
                                           FontSize="11"
                                           Margin="0,10,0,0"
                                           Foreground="#6B7280"
                                           helpers:DevInspector.Metadata="Layouts tip → Views/MainWindow.xaml (Layouts controls)" />
                                <CheckBox Content="Reserver IconGrid-slot"
                                          Margin="0,12,0,0"
                                          IsChecked="{Binding LayoutReserveIconGridSlot, Mode=TwoWay}"
                                          helpers:DevInspector.Metadata="Reserve IconGrid slot checkbox → MainViewModel.LayoutReserveIconGridSlot" />
                                <TextBlock FontSize="12"
                                           Margin="0,20,0,4">
                                    <TextBlock.Text>
                                        <Binding Path="LayoutPreset" StringFormat="Layoutkort: vælg IconGrid-slot til {0}." />
                                    </TextBlock.Text>
                                </TextBlock>
                                <StackPanel Orientation="Vertical"
                                            helpers:DevInspector.Metadata="Layout cards list → Views/MainWindow.xaml (Layouts controls)">
                                    <WrapPanel x:Name="LayoutCardsHost"
                                               Margin="0,4,0,0"
                                               ItemWidth="220"
                                               ItemHeight="260">
                                        <Border Margin="0,0,12,12"
                                                Padding="10"
                                                Background="#FFF7F7F7"
                                                BorderBrush="#FFE0E0E0"
                                                BorderThickness="1"
                                                CornerRadius="6">
                                            <StackPanel>
                                                <TextBlock Text="{Binding LayoutPreset}"
                                                           FontWeight="SemiBold"
                                                           FontSize="12"
                                                           Margin="0,0,0,4" />
                                <TextBlock Text="{Binding LayoutPreset, StringFormat={}{0} vælger layout ud fra synlige vinduer. Vælg IconGrid-slot:}"
                                                           FontSize="11"
                                                           Foreground="#6B7280"
                                                           TextWrapping="Wrap"
                                                           Margin="0,0,0,8" />
                                                <Grid Width="180"
                                                      Height="160">
                                                    <Grid.Resources>
                                                        <Style x:Key="LayoutSlotButtonStyle" TargetType="Button">
                                                            <Setter Property="Foreground" Value="White" />
                                                            <Setter Property="Background" Value="#FF1F2937" />
                                                            <Setter Property="BorderBrush" Value="#FF1F2937" />
                                                            <Setter Property="BorderThickness" Value="0" />
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border x:Name="border"
                                                                                Background="{TemplateBinding Background}"
                                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                                CornerRadius="4">
                                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                                              VerticalAlignment="Center" />
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="border" Property="Opacity" Value="0.9" />
                                                                            </Trigger>
                                                                            <Trigger Property="IsPressed" Value="True">
                                                                                <Setter TargetName="border" Property="Opacity" Value="0.8" />
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </Grid.Resources>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="*" />
                                                        <RowDefinition Height="*" />
                                                    </Grid.RowDefinitions>
                                                    <Button Click="LayoutSlotButton_Click"
                                                            Margin="4"
                                                            MinHeight="56"
                                                            Style="{StaticResource LayoutSlotButtonStyle}"
                                                            Tag="0">
                                                        <TextBlock Text="1"
                                                                   Foreground="White"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   TextAlignment="Center"
                                                                   TextWrapping="Wrap" />
                                                    </Button>
                                                    <Button Click="LayoutSlotButton_Click"
                                                            Margin="4"
                                                            MinHeight="56"
                                                            Style="{StaticResource LayoutSlotButtonStyle}"
                                                            Grid.Column="1"
                                                            Tag="1">
                                                        <TextBlock Text="2"
                                                                   Foreground="White"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   TextAlignment="Center"
                                                                   TextWrapping="Wrap" />
                                                    </Button>
                                                    <Button Click="LayoutSlotButton_Click"
                                                            Margin="4"
                                                            MinHeight="56"
                                                            Style="{StaticResource LayoutSlotButtonStyle}"
                                                            Grid.Row="1"
                                                            Tag="2">
                                                        <TextBlock Text="3"
                                                                   Foreground="White"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   TextAlignment="Center"
                                                                   TextWrapping="Wrap" />
                                                    </Button>
                                                    <Button Click="LayoutSlotButton_Click"
                                                            Margin="4"
                                                            MinHeight="56"
                                                            Style="{StaticResource LayoutSlotButtonStyle}"
                                                            Grid.Column="1"
                                                            Grid.Row="1"
                                                            Tag="3">
                                                        <TextBlock Text="4"
                                                                   Foreground="White"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   TextAlignment="Center"
                                                                   TextWrapping="Wrap" />
                                                    </Button>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </WrapPanel>
                                </StackPanel>

                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                    <Grid Visibility="{Binding IsHelpOpen, Converter={StaticResource BoolToVisibilityConverter}}"
                          Background="#FFF3F3F3"
                          helpers:DevInspector.Metadata="Help overlay root → Views/MainWindow.xaml (Help text)">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      CanContentScroll="True"
                                      helpers:DevInspector.Metadata="Help overlay scroller → Views/MainWindow.xaml (Help text)">
                            <StackPanel Margin="24"
                                        VerticalAlignment="Top"
                                        Orientation="Vertical"
                                        HorizontalAlignment="Center"
                                        MaxWidth="760"
                                        MinHeight="{Binding ContentHostHeight}"
                                        helpers:DevInspector.Metadata="Help stack → Views/MainWindow.xaml (Help text)">
                                <TextBlock Text="Help"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8"
                                           helpers:DevInspector.Metadata="Help title → Views/MainWindow.xaml (Help text)" />
                                <TextBlock Text="Forklaring på drag &amp; drop og temperaturer"
                                           FontSize="12"
                                           Margin="0,0,0,12"
                                           Foreground="#6B7280"
                                           TextAlignment="Left"
                                           helpers:DevInspector.Metadata="Help subtitle → Views/MainWindow.xaml (Help text)" />
                                <TextBlock Text="• Hvis du vil trække genveje fra Stifinder eller windows skrivebordet, skal IconGrid køre uden administratorrettigheder. Windows' UIPI-foranstaltning forhindrer Explorer i at sende drag-beskeder til høj-privilegerede vinduer."
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8"
                                           helpers:DevInspector.Metadata="Help drag/drop tip → Views/MainWindow.xaml (Help text)" />
                                <TextBlock Text="• Når IconGrid kører uden admin, kan LibreHardwareMonitor ikke læse CPU -sensorerne, så temperaturerne forbliver som --. Hvis du har brug for temperaturinfo, kør IconGrid som administrator og brug 'Tilføj'-Genvej knappen ved at højreklikke på katagori som Games, Højreklik på selve ikon området. Derefter kan man tilføje et genvejs ikon."
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8"
                                           helpers:DevInspector.Metadata="Help temp tip → Views/MainWindow.xaml (Help text)" />
                                <Button Content="Luk"
                                        Width="120"
                                        Padding="12,6"
                                        Margin="0,16,0,0"
                                        HorizontalAlignment="Left"
                                        helpers:DevInspector.Metadata="Close help button → Views/MainWindow.xaml (CloseHelpButton_Click)"
                                        Click="CloseHelpButton_Click" />
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
        <Canvas x:Name="DevOverlayCanvas"
                Panel.ZIndex="150"
                IsHitTestVisible="False">
            <Border x:Name="DevOverlayPanel"
                    Visibility="Collapsed"
                    Canvas.Left="8"
                    Canvas.Top="8"
                    Padding="8"
                    Background="#CC111720"
                    CornerRadius="6"
                    BorderBrush="#66FFFFFF"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock x:Name="DevOverlayHeader"
                               Foreground="White"
                               FontSize="11"
                               FontWeight="SemiBold"
                               LineHeight="14"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="DevOverlayDetails"
                               Foreground="#DDDDDD"
                               FontSize="10"
                               LineHeight="12"
                               Margin="0,4,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Canvas>
        </Grid>
    </Grid>
</Window>


