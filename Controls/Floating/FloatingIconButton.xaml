<UserControl x:Class="IconGrid.Controls.FloatingIconButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             Width="66"
             Height="66"
             Background="Transparent">
    <Button x:Name="InnerButton"
            Width="66"
            Height="66"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Margin="0,0,12,12"
            Padding="0"
            BorderThickness="0"
            Background="Transparent"
            PreviewMouseLeftButtonDown="InnerButton_PreviewMouseLeftButtonDown"
            PreviewMouseMove="InnerButton_PreviewMouseMove"
            PreviewMouseLeftButtonUp="InnerButton_PreviewMouseLeftButtonUp"
            Click="InnerButton_Click"
            ToolTip="{Binding ToolTipText, ElementName=Root}">
        <Button.ContextMenu>
            <ContextMenu>
                <MenuItem Header="{Binding ExitFullyLabel}" Click="ExitMenuItem_Click" />
            </ContextMenu>
        </Button.ContextMenu>
        <Button.Template>
            <ControlTemplate TargetType="Button">
                <Border Background="Transparent"
                        Padding="9">
                    <Border Width="48"
                            Height="48"
                            CornerRadius="12"
                            Background="{Binding AccentBrush, ElementName=Root}"
                            SnapsToDevicePixels="True"
                            UseLayoutRounding="True">
                        <UniformGrid Rows="3" Columns="3" Margin="6" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Ellipse Fill="White" Width="8" Height="8" />
                            <Ellipse Fill="White" Width="8" Height="8" />
                            <Ellipse Fill="White" Width="8" Height="8" />
                            <Ellipse Fill="White" Width="8" Height="8" />
                            <Ellipse Fill="White" Width="8" Height="8" />
                            <Ellipse Fill="White" Width="8" Height="8" />
                            <Ellipse Fill="White" Width="8" Height="8" />
                            <Ellipse Fill="White" Width="8" Height="8" />
                            <Ellipse Fill="White" Width="8" Height="8" />
                        </UniformGrid>
                    </Border>
                </Border>
            </ControlTemplate>
        </Button.Template>
    </Button>
</UserControl>
