<UserControl x:Class="IconGrid.Controls.LauncherLogo"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             Width="32"
             Height="32"
             SnapsToDevicePixels="True">
    <Grid>
        <Border Background="{Binding AccentBrush, ElementName=Root}"
                CornerRadius="6"
                SnapsToDevicePixels="True" />
        <Viewbox Stretch="Uniform" Margin="4">
            <UniformGrid Rows="3" Columns="3" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0">
                <Ellipse Fill="White" Width="10" Height="10" />
                <Ellipse Fill="White" Width="10" Height="10" />
                <Ellipse Fill="White" Width="10" Height="10" />
                <Ellipse Fill="White" Width="10" Height="10" />
                <Ellipse Fill="White" Width="10" Height="10" />
                <Ellipse Fill="White" Width="10" Height="10" />
                <Ellipse Fill="White" Width="10" Height="10" />
                <Ellipse Fill="White" Width="10" Height="10" />
                <Ellipse Fill="White" Width="10" Height="10" />
            </UniformGrid>
        </Viewbox>
    </Grid>
</UserControl>
