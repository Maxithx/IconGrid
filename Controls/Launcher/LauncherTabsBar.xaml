<UserControl x:Class="IconGrid.Controls.LauncherTabsBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:IconGrid.Helpers"
             x:Name="Root">
    <UserControl.Resources>
        <helpers:SelectedTabMatchConverter x:Key="SelectedTabMatchConverter" />
        <helpers:TabNameLocalizationConverter x:Key="TabNameLocalizationConverter" />
        <helpers:ScrollButtonsVisibilityConverter x:Key="ScrollButtonsVisibilityConverter" />
    </UserControl.Resources>
    <Grid Margin="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0" Margin="0"
              helpers:DevInspector.Metadata="Tab navigation host → Views/MainWindow.xaml (Tabs controls)">
            <ScrollViewer x:Name="TabsScrollViewer"
                          HorizontalScrollBarVisibility="Hidden"
                          VerticalScrollBarVisibility="Disabled"
                          Margin="0"
                          helpers:DevInspector.Metadata="Tabs scroll area → Views/MainWindow.xaml (Tabs controls)">
                <ItemsControl ItemsSource="{Binding Tabs}"
                              helpers:DevInspector.Metadata="Tabs items host → Views/MainWindow.xaml (Tabs controls)">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <RadioButton Margin="4,0"
                                         Style="{DynamicResource TabToggleStyle}"
                                         Command="{Binding DataContext.SelectTabCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                         CommandParameter="{Binding}"
                                         Click="TabToggle_Click"
                                         helpers:DevInspector.Metadata="{Binding ., StringFormat=Tab: {0} (ViewModels/MainViewModel.cs)}">
                                <RadioButton.ContextMenu>
                                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                        <MenuItem Header="{Binding DataContext.RenameLabel, Source={x:Reference Root}}" Click="RenameTabMenuItem_Click" />
                                        <MenuItem Header="{Binding DataContext.RemoveLabel, Source={x:Reference Root}}" Click="RemoveTabMenuItem_Click" />
                                    </ContextMenu>
                                </RadioButton.ContextMenu>
                                <RadioButton.IsChecked>
                                    <MultiBinding Converter="{StaticResource SelectedTabMatchConverter}" Mode="OneWay">
                                        <Binding />
                                        <Binding Path="DataContext.SelectedTab"
                                                 RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                    </MultiBinding>
                                </RadioButton.IsChecked>
                                <ContentPresenter>
                                    <ContentPresenter.Content>
                                        <MultiBinding Converter="{StaticResource TabNameLocalizationConverter}" Mode="OneWay">
                                            <Binding />
                                            <Binding Path="DataContext.Language" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                        </MultiBinding>
                                    </ContentPresenter.Content>
                                </ContentPresenter>
                            </RadioButton>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,8,0"
                    helpers:DevInspector.Metadata="Tab scroll controls → Views/MainWindow.xaml (Tabs controls)">
            <Button Style="{DynamicResource IconButtonStyle}"
                    Click="ScrollTabsLeft_Click"
                    ToolTip="Scroll left"
                    Margin="0,0,8,0"
                    Width="28" Height="28" Padding="0" VerticalAlignment="Center"
                    helpers:DevInspector.Metadata="Scroll tabs left button → Views/MainWindow.xaml (ScrollTabsLeft_Click)">
                <Button.Visibility>
                    <MultiBinding Converter="{StaticResource ScrollButtonsVisibilityConverter}" ConverterParameter="6">
                        <Binding Path="ShowScrollButtons" />
                        <Binding Path="Tabs.Count" />
                    </MultiBinding>
                </Button.Visibility>
                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE76B;" FontSize="13" VerticalAlignment="Center" />
            </Button>
            <Button Style="{DynamicResource IconButtonStyle}"
                    Click="ScrollTabsRight_Click"
                    ToolTip="Scroll right"
                    Width="28" Height="28" Padding="0" VerticalAlignment="Center"
                    helpers:DevInspector.Metadata="Scroll tabs right button → Views/MainWindow.xaml (ScrollTabsRight_Click)">
                <Button.Visibility>
                    <MultiBinding Converter="{StaticResource ScrollButtonsVisibilityConverter}" ConverterParameter="6">
                        <Binding Path="ShowScrollButtons" />
                        <Binding Path="Tabs.Count" />
                    </MultiBinding>
                </Button.Visibility>
                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE76C;" FontSize="13" VerticalAlignment="Center" />
            </Button>
        </StackPanel>
        <Button Grid.Column="2"
                Content="+"
                Style="{DynamicResource IconButtonStyle}"
                Click="AddTabButton_Click"
                Margin="0,0,4,0"
                Width="28" Height="28" Padding="0" VerticalAlignment="Center"
                helpers:DevInspector.Metadata="Add tab button → MainViewModel.AddTab" />
        <Button Grid.Column="3"
                Style="{DynamicResource IconButtonStyle}"
                Click="MoreButton_Click"
                ToolTip="Indstillinger"
                Margin="4,0,16,0"
                Width="28" Height="28" Padding="0" VerticalAlignment="Center"
                helpers:DevInspector.Metadata="More menu button → Views/MainWindow.xaml (MoreButton_Click)">
            <TextBlock Text="&#xE712;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center" />
        </Button>
    </Grid>
</UserControl>

