<UserControl x:Class="IconGrid.Controls.LauncherTopBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:IconGrid.Controls"
             x:Name="Root">
    <Grid x:Name="TopBarGrid"
          Background="Transparent"
          Height="Auto"
          VerticalAlignment="Top"
          UseLayoutRounding="False"
          SnapsToDevicePixels="False"
          Margin="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <controls:LauncherLogoArea Grid.Column="0"
                                   LogoClick="LogoButton_Click"
                                   LayoutContextMenuOpened="LayoutContextMenu_Opened" />

        <controls:LauncherMonitorRow Grid.Column="1" />

        <controls:LauncherWindowButtons Grid.Column="2"
                                        MinimizeClick="MinimizeButton_Click"
                                        CloseClick="CloseButton_Click" />
    </Grid>
</UserControl>
