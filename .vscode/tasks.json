{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Watch LM Studio Tokens",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-Command",
        "if (Get-Command python -ErrorAction SilentlyContinue) { python watch_tokens.py } elseif (Get-Command py -ErrorAction SilentlyContinue) { py watch_tokens.py } else { Write-Host 'Python blev ikke fundet i PATH. Start scriptet med din konkrete python.exe.' }"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "clear": false
      },
      "problemMatcher": []
    },
    {
        "label": "build",
        "command": "dotnet",
        "type": "process",
        "args": [
            "build",
            "${workspaceFolder}/IconGrid.sln",
            "/property:GenerateFullPaths=true",
            "/consoleloggerparameters:NoSummary;ForceNoAlign"
        ],
        "problemMatcher": "$msCompile"
    },
    {
        "label": "publish",
        "command": "dotnet",
        "type": "process",
        "args": [
            "publish",
            "${workspaceFolder}/IconGrid.sln",
            "/property:GenerateFullPaths=true",
            "/consoleloggerparameters:NoSummary;ForceNoAlign"
        ],
        "problemMatcher": "$msCompile"
    },
    {
        "label": "watch",
        "command": "dotnet",
        "type": "process",
        "args": [
            "watch",
            "run",
            "--project",
            "${workspaceFolder}/IconGrid.sln"
        ],
        "problemMatcher": "$msCompile"
    }
  ]
}
